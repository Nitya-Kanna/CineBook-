# Copy to .env and adjust. Never commit .env.

# Async SQLAlchemy URL (asyncpg). Must use postgresql+asyncpg scheme.
DATABASE_URL=postgresql+asyncpg://cinebook:cinebook@localhost:5432/cinebook

# Redis (caching, locks, Celery broker/backend in later phases)
REDIS_URL=redis://localhost:6379/0

# development | staging | production
ENV=development

# Log SQL; disable in production
DEBUG=true

# Phase 5 — JWT (placeholders)
JWT_SECRET_KEY=change-me-use-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
